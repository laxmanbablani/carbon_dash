{
  "name": "carbon_dash",
  "version": "0.0.1",
  "description": "Carbon React Components wrapped for Dash",
  "main": "build/index.js",
  "scripts": {
    "build:js": "webpack --mode production",
    "build:backends": "dash-generate-components ./src/lib/components carbon_dash -p package-info.json --ignore \\.test\\.",
