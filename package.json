    "react-dom": "^18.3.1",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^3.3.3",
    "styled-jsx": "^3.2.1",
    "typescript": "^6.0.2",
    "webpack": "^5.84.1",
